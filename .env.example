# Длинная случайная строка (минимум 32 символа) для шифрования сессии
SESSION_PASSWORD=change_me_to_a_long_random_string_at_least_32_chars

# Данные единственного администратора
ADMIN_LOGIN=admin
# bcrypt-хеш пароля. Сгенерировать: node scripts/hash.js "ваш_пароль"
ADMIN_PASSWORD_HASH=$2a$10$replace_with_real_hash

# Telegram бот для уведомлений о заявках (получить у @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
